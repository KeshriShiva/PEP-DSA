import java.util.*;

class SegmentTree {
    int[] seg;

    SegmentTree(int n) {
        seg = new int[4 * n];
    }

    public void build(int nodeIndex, int left, int right, int[] nums) {
        if (left == right) {
            seg[nodeIndex] = nums[left];
            return;
        }

        int mid = (left + right) >> 1;

        int leftChildIndex = (2 * nodeIndex) + 1;
        int rightChildIndex = (2 * nodeIndex) + 2;

        build(leftChildIndex, left, mid, nums);
        build(rightChildIndex, mid + 1, right, nums);

        seg[nodeIndex] = seg[leftChildIndex] + seg[rightChildIndex];
    }

    public int query(int nodeIndex, int queryLeft, int queryRight, int numsLeft, int numsRight) {

        // Completely inside
        if (numsLeft >= queryLeft && numsRight <= queryRight)
            return seg[nodeIndex];

        // Completely outside
        if (numsRight < queryLeft || numsLeft > queryRight)
            return 0;

        int mid = (numsLeft + numsRight) >> 1;

        int leftQueryRes = query((2 * nodeIndex) + 1, queryLeft, queryRight, numsLeft, mid);
        int rightQueryRes = query((2 * nodeIndex) + 2, queryLeft, queryRight, mid + 1, numsRight);

        return leftQueryRes + rightQueryRes;
    }

    public void update(int nodeIndex, int updateIndex, int updateValue, int numsLeft, int numsRight) {

        if (numsLeft == numsRight) {
            seg[nodeIndex] = updateValue;
            return;
        }

        int mid = (numsLeft + numsRight) >> 1;

        if (updateIndex <= mid)
            update((2 * nodeIndex) + 1, updateIndex, updateValue, numsLeft, mid);
        else
            update((2 * nodeIndex) + 2, updateIndex, updateValue, mid + 1, numsRight);

        seg[nodeIndex] = seg[(2 * nodeIndex) + 1] + seg[(2 * nodeIndex) + 2];
    }
}

public class Main {
    public static void main(String[] args) {

        int[] nums = {5, -1, 3, 2, -4};

        int n = nums.length;

        SegmentTree st = new SegmentTree(n);

        st.build(0, 0, n - 1, nums);

        System.out.println("Sum of values from 2 to 4 is: " +
                st.query(0, 2, 4, 0, n - 1));

        // Updating index 2 with value 5
        st.update(0, 2, 5, 0, n - 1);

        System.out.println("After update:");
        System.out.println("Sum of values from 2 to 4 is: " +
                st.query(0, 2, 4, 0, n - 1));
    }
}
